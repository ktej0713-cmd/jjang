{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent",
      "NotebookEdit",
      "TodoWrite",
      "mcp__pencil",
      "mcp__plugin_playwright_playwright__browser_press_key",
      "mcp__plugin_playwright_playwright__browser_handle_dialog",
      "mcp__claude_ai_Gmail__gmail_create_draft",
      "mcp__plugin_playwright_playwright__browser_close"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(: DROP TABLE)",
      "Bash(: DROP DATABASE)"
    ],
    "additionalDirectories": [
      "C:\\Users\\jj1\\.claude\\skills\\merge-worktree",
      "G:\\내 드라이브\\claude-config\\skills\\merge-worktree",
      "C:\\Users\\jj1\\.claude\\hooks",
      "G:\\내 드라이브\\claude-config\\hooks",
      "C:\\Users\\jj1\\.claude",
      "G:\\내 드라이브\\claude-config"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/scripts/enhance_prompt.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '(core/|vendor/|framework/)' && echo 'BLOCKED: core file protection - use module pattern' && exit 2 || exit 0",
            "timeout": 5,
            "statusMessage": "Core file protection check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.php$' && php -l \"$CLAUDE_FILE_PATH\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "PHP syntax check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/track-session.sh",
            "async": true,
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/commit-session.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/.claude && git pull origin master 2>/dev/null | grep -v 'Already up to date' || true && echo '짱베이스볼 MD팀 세션 시작' && echo '날짜: '$(date +%Y-%m-%d) && echo '팀: Lead MD(opus) > 소싱/콘텐츠/구조/프로모션 MD(sonnet) > 고객검증 MD(opus)' && echo '개발: PHP개발자 / 스킨디자이너 / 테스터 / SEO전문가' && echo '---'",
            "statusMessage": "세션 초기화 중..."
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/sync-skill-registry.py",
            "timeout": 10,
            "statusMessage": "스킬 레지스트리 동기화..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/load-recent-changes.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- 짱베이스볼 MD팀 컨텍스트 재주입 ---' && cat ~/.claude/jjang.md 2>/dev/null && echo '--- 팀: Lead MD(opus) > 소싱/콘텐츠/구조/프로모션 MD(sonnet) > 고객검증 MD(opus) | 개발: PHP/스킨/테스터/SEO ---'",
            "statusMessage": "팀 컨텍스트 재주입 중..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@skills": true,
    "example-skills@skills": true,
    "everything-claude-code@everything-claude-code": true,
    "php-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "playwright@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "firecrawl@firecrawl": true,
    "claude-mem@thedotmack": true,
    "review-loop@hamel-review": true,
    "cli-anything@cli-anything": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "firecrawl": {
      "source": {
        "source": "github",
        "repo": "firecrawl/firecrawl-claude-plugin"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "hamel-review": {
      "source": {
        "source": "github",
        "repo": "hamelsmu/claude-review-loop"
      }
    },
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
