# 고도몰 API 설정
GODO_PARTNER_KEY=your_partner_key_here
GODO_USER_KEY=your_user_key_here
GODO_SHOP_URL=https://yourshop.godomall.com

# Gmail 설정
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# 수신자 (쉼표로 복수 지정 가능)
RECIPIENT_EMAIL=recipient1@example.com,recipient2@example.com

# 모니터링 대상 상품번호 (쉼표로 복수 지정)
TARGET_GOODS_NOS=1000,1001,1002

# 재고 부족 기준 수량 (기본값: 10)
LOW_STOCK_THRESHOLD=10
